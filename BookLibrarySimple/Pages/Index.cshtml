@page
@model IndexModel
@{
    ViewData["Title"] = "Библиотека";
}

<h1>Список книг</h1>

<table class="table">
    <thead>
        <tr>
            <th>Название</th>
            <th>Автор</th>
            <th>Стиль</th>
            <th>Издательство</th>
            <th>Год</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model.Books)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author.FullName</td>
                <td>@book.Style.Name</td>
                <td>@book.Publisher.Name</td>
                <td>@book.Year</td>
                <td>
                    <a asp-page="/Details" asp-route-id="@book.Id">Подробнее</a>
                </td>
            </tr>
        }
    </tbody>
</table>