@page
@model IndexModel
@{
    ViewData["Title"] = "Библиотека";
}

<h1>Список книг</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label asp-for="SearchTitle" class="form-label">Название</label>
        <input asp-for="SearchTitle" class="form-control" placeholder="Часть названия" />
    </div>
    <div class="col-md-3">
        <label asp-for="SearchAuthor" class="form-label">Автор</label>
        <input asp-for="SearchAuthor" class="form-control" placeholder="ФИО автора" />
    </div>
    <div class="col-md-2">
        <label asp-for="SearchStyle" class="form-label">Стиль</label>
        <input asp-for="SearchStyle" class="form-control" placeholder="Стиль" />
    </div>
    <div class="col-md-2">
        <label asp-for="SearchPublisher" class="form-label">Издательство</label>
        <input asp-for="SearchPublisher" class="form-control" placeholder="Издательство" />
    </div>
    <div class="col-md-2">
        <label asp-for="SearchYear" class="form-label">Год</label>
        <input asp-for="SearchYear" class="form-control" placeholder="Год" />
    </div>
    <div class="col-md-2 align-self-end">
        <button type="submit">Найти</button>
        <a asp-page="./Index"><button type="button">Сброс</button></a>
    </div>
</form>

<p>
    <a asp-page="./Create"><button type="button">Добавить книгу</button></a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th>Автор</th>
            <th>Стиль</th>
            <th>Издательство</th>
            <th>Год</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model.Books)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author.FullName</td>
                <td>@book.Style.Name</td>
                <td>@book.Publisher.Name</td>
                <td>@book.Year</td>
                <td>
                    <a asp-page="./Details" asp-route-id="@book.Id"><button type="button">Детали</button></a>
                    <a asp-page="./Edit" asp-route-id="@book.Id"><button type="button">Изменить</button></a>
                    <a asp-page="./Delete" asp-route-id="@book.Id"><button type="button">Удалить</button></a>

                </td>
            </tr>
        }
    </tbody>
</table>